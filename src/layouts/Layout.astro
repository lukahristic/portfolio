---
import '../styles/global.css';

// Placeholder — replace with real Vercel URL before launch.
const BASE_URL = 'https://portfolio-wency.vercel.app';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Wency — Product Builder',
  description = 'Product builder who finds real problems, builds solutions, and ships — deliberately.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, BASE_URL);
const ogImageURL = new URL(ogImage, BASE_URL);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {/* Set the JS flag before paint so the hidden reveal state never flashes for no-JS users. */}
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <slot />

    <script>
      // The page's only motion JS: smooth scroll (Lenis) + reveal-on-scroll.
      // Bundled + deferred by Astro.
      import Lenis from 'lenis';

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const NAV_OFFSET = 64; // px — matches scroll-margin-top: 4rem under the fixed nav

      // ── Smooth scroll ─────────────────────────────────────────────────────────
      // Disabled only for prefers-reduced-motion. On touch devices Lenis leaves
      // native finger-scroll alone (smoothTouch: false is the default) but still
      // handles programmatic scrollTo() calls — so anchor links feel smooth on
      // every device without fighting the browser's momentum scroll.
      let lenis: Lenis | null = null;
      if (!reduce) {
        lenis = new Lenis({
          lerp: 0.1,           // calm glide — "expensive magazine", not ice rink
          smoothWheel: true,
        });
        const raf = (time: number) => {
          lenis!.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);
      }

      // ── Anchor links ──────────────────────────────────────────────────────────
      // Route hash links through Lenis (with nav offset); fall back to native.
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const hash = a.getAttribute('href');
          if (!hash || hash === '#') return;
          const target = document.querySelector<HTMLElement>(hash);
          if (!target) return;
          e.preventDefault();
          if (lenis) {
            lenis.scrollTo(target, { offset: -NAV_OFFSET, duration: 1.2 });
          } else {
            target.scrollIntoView(); // reduced-motion: instant jump, uses scroll-margin-top
          }
          history.pushState(null, '', hash);
        });
      });

      // ── Reveal-on-scroll ──────────────────────────────────────────────────────
      // Reveal-once, reading-friendly (never re-hides on scroll-up).
      const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      }

      // ── Before / after wipe ───────────────────────────────────────────────────
      // Upgrade to the pinned wipe unless reduced-motion (then it stays side-by-side).
      // Reveal-once when the frame is well into view.
      const baFigs = document.querySelectorAll<HTMLElement>('[data-ba]');
      if (!reduce && baFigs.length) {
        const isTouch = window.matchMedia('(hover: none)').matches;

        baFigs.forEach((fig) => {
          fig.classList.add('ba--wipe');
          // Touch: tap toggles a peek back at the "before". Desktop uses :hover (CSS).
          if (isTouch) {
            fig.addEventListener('click', () => {
              if (fig.classList.contains('is-ba-revealed')) fig.classList.toggle('ba--peek');
            });
          }
        });

        // Enable hover/tap compare only after the dramatic first wipe completes.
        const enableCompare = (fig: HTMLElement) => {
          const after = fig.querySelector('.ba__after');
          if (after) {
            after.addEventListener('transitionend', () => fig.classList.add('ba--interactive'), { once: true });
          } else {
            fig.classList.add('ba--interactive');
          }
        };

        if ('IntersectionObserver' in window) {
          const baIo = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  const fig = entry.target as HTMLElement;
                  fig.classList.add('is-ba-revealed');
                  baIo.unobserve(fig);
                  enableCompare(fig);
                }
              }
            },
            { threshold: 0.4 }
          );
          baFigs.forEach((f) => baIo.observe(f));
        } else {
          baFigs.forEach((f) => f.classList.add('is-ba-revealed', 'ba--interactive'));
        }
      }

      // ── Spottr chapter marker ─────────────────────────────────────────────────
      // Scrollspy: update the sticky running head to the current case-study beat.
      const beatLabel = document.querySelector<HTMLElement>('[data-beat-label]');
      const beats = document.querySelectorAll<HTMLElement>('[data-beat]');
      if (beatLabel && beats.length && 'IntersectionObserver' in window) {
        const beatIo = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                beatLabel.textContent = (entry.target as HTMLElement).dataset.beat ?? '';
              }
            }
          },
          { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
        );
        beats.forEach((b) => beatIo.observe(b));
      }
    </script>
  </body>
</html>
