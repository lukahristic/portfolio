---
import { experiments } from '../data/experiments';

const featured = experiments.filter((e) => e.featured === true);
const secondary = experiments.filter((e) => e.featured !== true);
---

<section id="lab" class="bg-paper-mid border-t border-paper-dark">
  <div class="max-w-4xl mx-auto px-6 py-24">

    <div data-reveal class="flex items-center gap-4 mb-16">
      <p class="font-body text-sm text-ink-muted uppercase tracking-widest">Experiments</p>
      <span class="flex-1 border-t border-paper-dark"></span>
      <span class="font-body text-xs text-ink-faint uppercase tracking-wider">Lab</span>
    </div>

    <h2
      data-reveal
      class="font-display text-4xl md:text-5xl font-light text-ink mb-6"
      style="line-height: var(--leading-tight);"
    >
      Systems Lab.
    </h2>

    <p
      data-reveal
      data-reveal-delay="1"
      class="font-body text-lg text-ink-muted mb-4"
      style="max-width: 52ch; line-height: var(--leading-normal);"
    >
      Not every insight comes from shipping a product. Some come from hitting a wall,
      diagnosing why, and building the fix into the system.
    </p>

    <p
      data-reveal
      data-reveal-delay="2"
      class="font-body text-lg text-ink-muted mb-16"
      style="max-width: 52ch; line-height: var(--leading-normal);"
    >
      These are the AI engineering decisions I've made in the open — memory architectures,
      prompt systems, security patterns, context engineering.
      Built to understand. Documented to reuse.
    </p>

    <div data-reveal data-reveal-delay="3" class="flex flex-col gap-2 mb-8">
      {featured.map((experiment) => (
        <div
          class="featured-exp-row border border-paper-dark rounded-lg overflow-hidden"
          style="border-left-width: 3px;"
          data-expanded="false"
          data-id={experiment.id}
        >
          <button
            class="feat-toggle w-full text-left flex items-start gap-4 px-4 py-3"
            aria-expanded="false"
            aria-controls={`feat-detail-${experiment.id}`}
          >
            <div class="flex-1 min-w-0">
              <span class="font-body text-sm text-ink-muted block mb-2" style="line-height: var(--leading-snug);">{experiment.title}</span>
              <div class="flex flex-wrap gap-1">
                {experiment.tech.map((t) => (
                  <span class="font-body text-xs text-ink-faint border border-paper-dark px-2 py-0.5 rounded">{t}</span>
                ))}
              </div>
            </div>
            <span class="card-expand-icon flex-shrink-0 mt-0.5" aria-hidden="true">+</span>
          </button>
          <div class="card-expandable" id={`feat-detail-${experiment.id}`}>
            <div class="card-inner">
              <div style="border-top: 1px solid var(--color-paper-dark); margin: 0 1rem;"></div>
              <div class="px-4 py-4">
                <p class="font-body text-sm text-ink mb-4" style="line-height: var(--leading-normal);">{experiment.description}</p>
                <div class="insight-callout">
                  <p class="font-display text-sm text-ink font-light" style="font-style: italic; line-height: var(--leading-snug);">{experiment.insight}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {secondary.length > 0 && (
      <div data-reveal>
        <p class="font-body text-xs text-ink-faint uppercase tracking-widest mb-4">More experiments</p>
        <div class="flex flex-col gap-2">
          {secondary.map((experiment) => (
            <div class="flex items-start gap-4 px-4 py-3 border border-paper-dark rounded-lg">
              <div>
                <p class="font-body text-sm text-ink-muted mb-2" style="line-height: var(--leading-snug);">{experiment.title}</p>
                <div class="flex flex-wrap gap-1">
                  {experiment.tech.map((t) => (
                    <span class="font-body text-xs text-ink-faint border border-paper-dark px-2 py-0.5 rounded">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .featured-exp-row {
    transition: border-left-color var(--dur-micro) var(--ease-out-soft);
  }
  .featured-exp-row[data-expanded="true"],
  .featured-exp-row:has(.feat-toggle:hover) {
    border-left-color: var(--color-accent);
  }
  .featured-exp-row[data-expanded="true"] .card-expandable {
    grid-template-rows: 1fr;
  }
  .featured-exp-row[data-expanded="true"] .card-expand-icon {
    transform: rotate(45deg);
    color: var(--color-accent);
  }
  .featured-exp-row[data-expanded="true"] .insight-callout {
    border-left-color: var(--color-accent);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.featured-exp-row').forEach((row) => {
    const toggle = row.querySelector<HTMLButtonElement>('.feat-toggle');
    toggle?.addEventListener('click', () => {
      const expanded = row.getAttribute('data-expanded') === 'true';
      row.setAttribute('data-expanded', String(!expanded));
      toggle.setAttribute('aria-expanded', String(!expanded));
    });
  });
</script>
