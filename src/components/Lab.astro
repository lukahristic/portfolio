---
import { experiments } from '../data/experiments';
import ExperimentCard from './ExperimentCard.astro';

const featured = experiments.filter((e) => e.featured === true);
const secondary = experiments.filter((e) => e.featured !== true);
---

<section id="lab" class="bg-paper-mid border-t border-paper-dark">
  <div class="max-w-4xl mx-auto px-6 py-24">

    <div data-reveal class="flex items-center gap-4 mb-16">
      <p class="font-body text-sm text-ink-muted uppercase tracking-widest">Experiments</p>
      <span class="flex-1 border-t border-paper-dark"></span>
      <span class="font-body text-xs text-ink-faint uppercase tracking-wider">Lab</span>
    </div>

    <h2
      data-reveal
      class="font-display text-4xl md:text-5xl font-light text-ink mb-6"
      style="line-height: var(--leading-tight);"
    >
      Systems Lab.
    </h2>

    <p
      data-reveal
      data-reveal-delay="1"
      class="font-body text-lg text-ink-muted mb-4"
      style="max-width: 52ch; line-height: var(--leading-normal);"
    >
      Not every insight comes from shipping a product. Some come from hitting a wall,
      diagnosing why, and building the fix into the system.
    </p>

    <p
      data-reveal
      data-reveal-delay="2"
      class="font-body text-lg text-ink-muted mb-16"
      style="max-width: 52ch; line-height: var(--leading-normal);"
    >
      These are the AI engineering decisions I've made in the open — memory architectures,
      prompt systems, security patterns, context engineering.
      Built to understand. Documented to reuse.
    </p>

    <div data-reveal data-reveal-delay="3" class="grid md:grid-cols-2 gap-4 mb-12">
      {featured.map((experiment) => (
        <ExperimentCard experiment={experiment} />
      ))}
    </div>

    {secondary.length > 0 && (
      <div data-reveal>
        <p class="font-body text-xs text-ink-faint uppercase tracking-widest mb-4">More experiments</p>
        <div class="flex flex-col gap-2">
          {secondary.map((experiment) => (
            <div class="flex items-start gap-4 px-4 py-3 border border-paper-dark rounded-lg">
              <div>
                <p class="font-body text-sm text-ink-muted mb-2" style="line-height: var(--leading-snug);">{experiment.title}</p>
                <div class="flex flex-wrap gap-1">
                  {experiment.tech.map((t) => (
                    <span class="font-body text-xs text-ink-faint border border-paper-dark px-2 py-0.5 rounded">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>
</section>
